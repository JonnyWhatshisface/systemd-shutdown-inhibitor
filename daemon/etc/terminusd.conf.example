# terminusd.conf
#
# Configuration for the systemd shutdown inhibitor daemon.
# The config file uses INI format. The [main] section holds global daemon
# settings. Each additional named section defines a script to run when a
# shutdown or reboot is requested.
# Additional drop-in files can be placed in /etc/terminus.d/.
# Drop-ins are loaded after this file in lexical filename order, and later
# values override earlier values for [main] and same-named script sections.

[main]

# Whether the daemon should update /etc/systemd/logind.conf to enforce
# InhibitDelayMaxSec. If false or omitted, logind.conf is left unchanged.
#set_max_inhibit_delay = false

# Maximum inhibit delay in seconds. Choose a value large enough to cover the
# total runtime of all configured scripts. Only meaningful when
# set_max_inhibit_delay = true.
#max_inhibit_delay = 1800

# Whether to restart systemd-logind.service after updating logind.conf.
# WARNING: this will terminate all active login sessions.
# Only meaningful when set_max_inhibit_delay = true.
#restart_logind_after_set = false

# ── shutdown_guard ────────────────────────────────────────────────────────
# The shutdown_guard runs a user-provided command to dynamically control
# whether shutdown/reboot targets are masked.  When the guard decides the
# system should not be rebooted it masks the relevant systemd targets at
# runtime (shutdown.target, reboot.target, poweroff.target, kexec.target,
# halt.target) and unmasks them when conditions are met again.
#
# shutdown_guard_enabled — must be set to true to activate the guard.
#                          Default: false.
shutdown_guard_enabled = true

# shutdown_guard_command — path to the executable, with optional arguments.
shutdown_guard_command = /opt/terminusd/scripts/example-persistent-shutdown-guard.sh

# shutdown_guard_type — oneshot or persist.  Default: oneshot.
#
#   oneshot  runs the command every shutdown_guard_interval seconds.
#            After shutdown_guard_threshold consecutive non-zero exits the
#            targets are masked.  They are unmasked the first time the
#            command returns 0.  The interval and threshold settings are
#            only meaningful in this mode.
#
#   persist  forks the command once and keeps it running indefinitely.
#            If it exits for any reason it is restarted immediately.
#            The process controls masking by writing to its stdout:
#                shutdown_guard_disable_shutdown 1   → disable shutdowns
#                shutdown_guard_disable_shutdown 0   → enable shutdowns
#            These directives may be emitted as many times as needed.
#            All other output is forwarded to syslog.
#
shutdown_guard_type = persist

# shutdown_guard_interval — seconds between oneshot runs.  Default: 30.
#shutdown_guard_interval = 30

# shutdown_guard_threshold — consecutive non-zero exits before masking
#                            in oneshot mode.  Default: 1.
#shutdown_guard_threshold = 1

# shutdown_guard_run_as_user  — drop privileges to this user.  Optional.
#shutdown_guard_run_as_user = root

# shutdown_guard_run_as_group — drop privileges to this group.  Optional.
#shutdown_guard_run_as_group = root

# shutdown_guard_run_env — path to a KEY=VALUE environment file.  Optional.
#shutdown_guard_run_env = /etc/terminusd/guard.env

#
# Shutdown Actions/Scripts
#
# Scripts/binaries to execute can be added here or in drop-ins.
# Section names are arbitrary labels used in log messages.
# The format of the files should contain:
# [name]      - The unique logical name of the script or application for log purposes.
#
# command     - Path to an executable script or binary and any arguments.
# priority    - Commands are run in ascending priority order.
#               Scripts with equal priority run in parallel.
#               Defaults to 1000 if omitted.
# user        - Drop privileges to this user before exec. Optional.
# group       - Drop privileges to this group before exec. Optional.
# env         - Path to a KEY=VALUE environment file. Optional.
#               If omitted the run inherits the daemon's environment.
# critical    - Boolean (1/0, true/false, yes/no). If true and this
#               script exits non-zero, no later priority groups run.
# enabled     - Boolean (1/0, true/false, yes/no). If false, this
#               script is completely ignored and not loaded.
#               Defaults to true if omitted.
#
# Example script configurations are provided as drop-in files in
# /etc/terminus.d/ which can be enabled or customized as needed.

